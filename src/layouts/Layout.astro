---
interface Props {
	title: string;
	lang?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { 
	title, 
	lang = "en", 
	description = "Vequalia - Intelligence for A Better Self. We craft AI tools to focus your mind, grow your prosperity, and protect your truth.",
	image = "/favicon.svg",
	canonicalURL = Astro.url.href
} = Astro.props;

// 定義不同語言對應的優化字體鏈接
const fontLinks = {
  zh: "https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Lexend:wght@500&family=Playfair+Display:ital@1&family=Noto+Sans+TC:wght@300;400;500;600&family=Noto+Serif+TC:wght@400;500&text=VEQUALIAOriaLaminaKeePass01267©、。「」万上下与世中之于人代们体保們候入共关具再出利前力加助半单发取名后命啟單在地址基境守将將專對就工年後徑思您感慧成我所推據数數文於早昇明是智最有期本权根權注淬演澄灵為煉物犀理生由界留當發的皆盛真研確礎示禮私稍筆简築粹精系約純緒繁繫约而聯與華萬補言計設試語誤請謝護讚象路透過邊量關隱靈非預预體魂，&display=swap",
  sc: "https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Lexend:wght@500&family=Playfair+Display:ital@1&family=Noto+Sans+SC:wght@300;400;500;600&family=Noto+Serif+SC:wght@400;500&text=VEQUALIAOriaLaminaKeePass01267©“”、。万上下与专世中为之于人代们体保們候入共关具再出利前力加助升半华单发取名后启命單在地址基境守对将將就工年後徑思您感成我所护推據数數文於早明是智最有期本权根權注淬演澄灵炼物犀理生由界留當發的皆盛真研确礎示礼私稍笔筑简粹精系約繁繫约纯绪而联能與萬補言試語誤請謝计设试误请谢象赞路输边过通量關隐靈非預预體魂，&display=swap",
  en: "https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Lexend:wght@500&family=Playfair+Display:ital@1&display=swap",
  fr: "https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Lexend:wght@500&family=Playfair+Display:ital@1&display=swap"
};

const currentFontLink = fontLinks[lang] || fontLinks.en;

// 構建語言交替鏈接
const languages = ['en', 'zh', 'sc', 'fr'];
const siteUrl = "https://vequalia.com"; // 請確保這是您的正式網址

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Vequalia",
  "alternateName": "Vequalia AI",
  "url": siteUrl,
  "description": description
};

const organizationData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Vequalia",
  "url": siteUrl,
  "logo": siteUrl + "/favicon.svg"
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, siteUrl)} />
		<meta property="og:site_name" content="Vequalia" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, siteUrl)} />

		<!-- Language Alternates -->
		<link rel="alternate" hreflang="en" href={`${siteUrl}/`} />
		<link rel="alternate" hreflang="zh-Hant" href={`${siteUrl}/zh/`} />
		<link rel="alternate" hreflang="zh-Hans" href={`${siteUrl}/sc/`} />
		<link rel="alternate" hreflang="fr" href={`${siteUrl}/fr/`} />
		<link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

		<link rel="stylesheet" href="/style.css" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href={currentFontLink} rel="stylesheet" />

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<script type="application/ld+json" set:html={JSON.stringify(organizationData)} />

		<!-- Cloudflare Web Analytics -->
		<script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "5cd8749930ec4d58955b8546a088cf8a"}'></script>
		<!-- End Cloudflare Web Analytics -->
	</head>
	<body>
		<slot />
		<script is:inline src="/main.js"></script>
	</body>
</html>
