---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const lang = 'zh';
---

<Layout title="Vequalia - 淬煉本真" lang={lang}>
	<Navbar lang={lang} />

	<header class="hero" id="about">
		<div class="container hero-content animate-fade-up">
			<h1>智啟靈犀，<br><span class="italic-serif typewriter-text">淬煉本真</span></h1>
			<p class="subtitle delay-1">我們研發人工智慧，非為取代，而在於昇華。透過精確設計的工具，助您澄明思緒、共築繁盛、守護真我之境。</p>
		</div>
	</header>

	<main>
		<section id="oria" class="product-section alternate">
			<div class="container grid">
				<div class="content reveal">
					<span class="product-label">「專注，是生命對世界最純粹的禮讚。」</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">Oria</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">將於 2026 年下半年 推出</span>
					</div>
				</div>
				<div class="visual reveal">
					<div class="oria-canvas">
						<div class="oria-shape ring-1"></div>
						<div class="oria-shape ring-2"></div>
						<div class="oria-shape ring-3"></div>
					</div>
				</div>
			</div>
		</section>

		<section id="lamina" class="product-section">
			<div class="container grid">
				<div class="visual reveal">
					<div class="lamina-canvas">
						<div class="lamina-grid"></div>
						<div class="lamina-lines">
							<span></span><span></span><span></span><span></span><span></span>
						</div>
					</div>
				</div>
				<div class="content reveal">
					<span class="product-label">「萬象之本，皆由數理筆就。」</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">Lamina</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">將於 2026 年下半年 推出</span>
					</div>
				</div>
			</div>
		</section>

		<section id="keepass" class="product-section alternate">
			<div class="container grid">
				<div class="content reveal">
					<span class="product-label">「隱私，是守護靈魂邊界的力量。」</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">KeePass</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">將於 2027 年上半年 推出</span>
					</div>
				</div>
				<div class="visual reveal">
					<div class="keepass-canvas">
						<div class="keepass-outer"></div>
						<div class="keepass-shape"></div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer lang={lang} />
</Layout>
