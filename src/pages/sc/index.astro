---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import EmailCapture from '../../components/EmailCapture.astro';

const lang = 'sc';
---

<Layout 
	title="Vequalia - 智启灵犀，淬炼本真" 
	lang={lang}
	description="Vequalia 旨在通过精确设计的人工智能工具助您澄明思绪、共筑繁盛、守护真我之境。"
>
	<Navbar lang={lang} />

	<header class="hero" id="about">
		<div class="container hero-content animate-fade-up">
			<h1>智启灵犀，<br><span class="italic-serif typewriter-text">淬炼本真</span></h1>
			<p class="subtitle delay-1">我们研发人工智能，非为取代，而在於升华。通过精确设计的工具，助您澄明思绪、共筑繁盛、守护真我之境。</p>
		</div>
	</header>

	<main>
		<section id="oria" class="product-section alternate">
			<div class="container grid">
				<div class="content reveal">
					<span class="product-label">“专注，是生命对世界最纯粹的礼赞。”</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">Oria</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">将于 2026 年下半年 推出</span>
					</div>
					<EmailCapture lang={lang} />
				</div>
				<div class="visual reveal">
					<div class="oria-canvas">
						<div class="oria-shape ring-1"></div>
						<div class="oria-shape ring-2"></div>
						<div class="oria-shape ring-3"></div>
					</div>
				</div>
			</div>
		</section>

		<section id="lamina" class="product-section">
			<div class="container grid">
				<div class="visual reveal">
					<div class="lamina-canvas">
						<div class="lamina-grid"></div>
						<div class="lamina-lines">
							<span></span><span></span><span></span><span></span><span></span>
						</div>
					</div>
				</div>
				<div class="content reveal">
					<span class="product-label">“万象之本，皆由数理笔就。”</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">Lamina</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">将于 2026 年下半年 推出</span>
					</div>
				</div>
			</div>
		</section>

		<section id="keepass" class="product-section alternate">
			<div class="container grid">
				<div class="content reveal">
					<span class="product-label">“隐私，是守护灵魂边界的力量。”</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">KeePass</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">将于 2027 年上半年 推出</span>
					</div>
				</div>
				<div class="visual reveal">
					<div class="keepass-canvas">
						<div class="keepass-outer"></div>
						<div class="keepass-shape"></div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer lang={lang} />
</Layout>
