---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const lang = 'fr';
---

<Layout title="Vequalia - L'Éveil du Soi" lang={lang}>
	<Navbar lang={lang} />

	<header class="hero" id="about">
		<div class="container hero-content animate-fade-up">
			<h1>L'intelligence pour<br><span class="italic-serif typewriter-text">l'Éveil du Soi</span></h1>
			<p class="subtitle delay-1">Nous façonnons l'intelligence artificielle non pour supplanter l'humain, mais pour l'exalter. Une suite d'instruments ciselés pour la clarté de l'esprit, la quête d'abondance et le sanctuaire de votre vérité.</p>
		</div>
	</header>

	<main>
		<section id="oria" class="product-section alternate">
			<div class="container grid">
				<div class="content reveal">
					<span class="product-label">« L’attention est la forme la plus rare et la plus pure de la générosité. »</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">Oria</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">Éclosion prévue au S2 2026</span>
					</div>
				</div>
				<div class="visual reveal">
					<div class="oria-canvas">
						<div class="oria-shape ring-1"></div>
						<div class="oria-shape ring-2"></div>
						<div class="oria-shape ring-3"></div>
					</div>
				</div>
			</div>
		</section>

		<section id="lamina" class="product-section">
			<div class="container grid">
				<div class="visual reveal">
					<div class="lamina-canvas">
						<div class="lamina-grid"></div>
						<div class="lamina-lines">
							<span></span><span></span><span></span><span></span><span></span>
						</div>
					</div>
				</div>
				<div class="content reveal">
					<span class="product-label">« Le livre de la nature est écrit en langage mathématique. »</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">Lamina</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">Éclosion prévue au S2 2026</span>
					</div>
				</div>
			</div>
		</section>

		<section id="keepass" class="product-section alternate">
			<div class="container grid">
				<div class="content reveal">
					<span class="product-label">« La vie privée est le pouvoir de se révéler au monde avec parcimonie. »</span>
					<div class="accent-line"></div>
					<h2 class="reveal title-wipe">KeePass</h2>
					<div class="product-timeline">
						<span class="timeline-dot"></span>
						<span class="timeline-text">Éclosion prévue au S1 2027</span>
					</div>
				</div>
				<div class="visual reveal">
					<div class="keepass-canvas">
						<div class="keepass-outer"></div>
						<div class="keepass-shape"></div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer lang={lang} />
</Layout>
